<!DOCTYPE html>
<html>
<head>
  <title>Signup</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: linear-gradient(120deg, #4e73df, #1cc88a); height:100vh; display:flex; justify-content:center; align-items:center; }
    .card { border-radius:15px; padding:30px; width:350px; }
  </style>
</head>
<body>
  <div class="card shadow">
    <h3 class="text-center mb-3">Signup</h3>
    <form action="/signup" method="POST">
      <input type="text" name="name" class="form-control mb-3" placeholder="Name" required>
      <input type="email" name="email" class="form-control mb-3" placeholder="Email" required>
      <input type="password" name="password" class="form-control mb-3" placeholder="Password (6+ chars)" required>
      <button class="btn btn-primary w-100">Signup</button>
    </form>
    <p class="text-center mt-3">Already have an account? <a href="/signin">Signin</a></p>
  </div>
</body>
</html>