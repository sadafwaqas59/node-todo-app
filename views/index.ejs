<!DOCTYPE html>
<html>
<head>
  <title>Todo Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background:#f5f7fb; }
    .todo-done { text-decoration: line-through; color: gray; }
    img { border-radius:5px; margin-top:5px; }
  </style>
</head>
<body>
<nav class="navbar navbar-dark bg-dark">
  <div class="container">
    <span class="navbar-brand">Todo App</span>
    <a href="/logout" class="btn btn-danger btn-sm">Logout</a>
  </div>
</nav>

<div class="container mt-4">
  <div class="card shadow p-4">
    <h4>Add Task</h4>
    <form action="/add" method="POST" enctype="multipart/form-data">
      <div class="row">
        <div class="col-md-6">
          <input type="text" name="task" class="form-control" placeholder="Enter task" required>
        </div>
        <div class="col-md-3">
          <input type="file" name="image" class="form-control">
        </div>
        <div class="col-md-3">
          <button class="btn btn-success w-100">Add</button>
        </div>
      </div>
    </form>

    <hr>

    <ul class="list-group mt-3">
      <% todos.forEach(todo => { %>
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <div>
          <span class="<%= todo.isCompleted ? 'todo-done':'' %>"><%= todo.task %></span>
          <% if(todo.image){ %>
            <br>
            <img src="/uploads/<%= todo.image %>" width="120">
          <% } %>
        </div>
        <div>
          <a href="/complete/<%= todo._id %>" class="btn btn-success btn-sm">Done</a>
          <a href="/delete/<%= todo._id %>" class="btn btn-danger btn-sm">Delete</a>
        </div>
      </li>
      <% }) %>
    </ul>
  </div>
</div>
</body>
</html>